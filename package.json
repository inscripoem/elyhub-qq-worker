{
  "name": "elyhub-qq-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n backend,ui -c blue,green \"bun run --watch src/main.ts\" \"vite\"",
    "dev:backend": "bun run --watch src/main.ts",
    "dev:ui": "vite",
    "build": "vite build",
    "start": "bun run src/main.ts",
    "check": "tsc --noEmit && tsc --project src/ui/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@elysiajs/static": "^1.1.1",
    "antd": "^6.3.1",
    "croner": "^10.0.1",
    "elysia": "^1.1.20",
    "node-napcat-ts": "^0.4.21",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-js-cron": "^5.2.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "bun-types": "^1.2.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.6.3",
    "vite": "^7.3.1"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "packageManager": "bun@1.2.0"
}
